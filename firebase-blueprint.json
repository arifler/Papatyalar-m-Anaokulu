{
  "entities": {
    "SiteContent": {
      "title": "Site Content",
      "description": "General content for the website sections",
      "type": "object",
      "properties": {
        "hero": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "subtitle": { "type": "string" },
            "description": { "type": "string" },
            "imageUrl": { "type": "string" }
          }
        },
        "slides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "subtitle": { "type": "string" },
              "imageUrl": { "type": "string" }
            }
          }
        },
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "desc": { "type": "string" },
              "iconName": { "type": "string" }
            }
          }
        },
        "education": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "items": { "type": "array", "items": { "type": "string" } },
            "imageUrl1": { "type": "string" },
            "imageUrl2": { "type": "string" }
          }
        },
        "workshops": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "imageUrl": { "type": "string" },
              "color": { "type": "string" }
            }
          }
        },
        "contact": {
          "type": "object",
          "properties": {
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "instagram": { "type": "string" }
          }
        },
        "slideDuration": { "type": "number", "description": "Duration of each slide in seconds" }
      }
    },
    "GalleryImage": {
      "title": "Gallery Image",
      "description": "An image in the school gallery",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "caption": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url"]
    },
    "Message": {
      "title": "Contact Message",
      "description": "A message sent from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "read", "archived"] }
      },
      "required": ["name", "phone"]
    }
  },
  "firestore": {
    "content/main": {
      "schema": "SiteContent",
      "description": "Main document containing all editable site content"
    },
    "gallery/{imageId}": {
      "schema": "GalleryImage",
      "description": "Collection of images for the school gallery"
    },
    "messages/{messageId}": {
      "schema": "Message",
      "description": "Collection of contact form submissions"
    }
  }
}
